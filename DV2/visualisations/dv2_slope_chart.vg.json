{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Inbound vs Outbound Flights"},
    "width": 1000,
    "height": 400,
    "data": {
        "url": "https://raw.githubusercontent.com/clkride/airline_routes/refs/heads/main/query_results/Inbound%20Outbound%20Traffic.csv"
    },
    "transform": [
        {"filter": "datum.airport_country == 'Malaysia'"},
        {
            "calculate": "toNumber(datum.num_inbound_flights)",
            "as": "inbound"
        },
        {
            "calculate": "toNumber(datum.num_outbound_flights)",
            "as": "outbound"
        },
        {
            "fold": ["inbound", "outbound"],
            "as": ["type", "value"]
        }
    ],
    "mark": {
        "type": "line",
        "point": true
    },
    "encoding": {
        "x": {
            "field": "type",
            "type": "nominal"
        },
        "y": {
            "field": "value",
            "type": "quantitative",
            "title": "Number of Flights"
        },
        "color": {
            "field": "airport_name",
            "type": "nominal",
            "legend": null
        },
        "detail": {
            "field": "airport_name"
        },
        "tooltip": [
            {"field": "type", "type": "nominal"},
            {"field": "value", "type": "quantitative"},
            {"field": "airport_name", "type": "nominal"}
        ]
    }
}
{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Country-wise Tourism vs Gender Imbalance"},
    "width": 400,
    "height": 300,
    "data": {
        "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/MY_montharr_ns.csv",
        "format": {"type": "csv"}
    },
    "transform": [
        {"filter": "datum.country != 'ALL'"},
        {
            "aggregate": [
                {"op": "sum", "field": "arrivals", "as": "total_arrivals"},
                {"op": "sum", "field": "arrivals_male", "as": "male_total"},
                {"op": "sum", "field": "arrivals_female", "as": "female_total"}
            ],
            "groupby": ["country"]
        },
        {
            "calculate": "abs(datum.male_total - datum.female_total)",
            "as": "imbalance"
        },
        {
            "window": [{"op": "rank", "as": "rank"}],
            "sort": [{"field": "total_arrivals", "order": "descending"}]
        },
        {"filter": "datum.rank <= 30"}
    ],
    "mark": {"type": "circle", "size": 50, "opacity": 1},
    "encoding": {
        "x": {
            "field": "total_arrivals",
            "type": "quantitative",
            "title": "Total Arrivals (All Years)",
            "axis": {"format": "s"}
        },
        "y": {
            "field": "imbalance",
            "type": "quantitative",
            "title": "Gender Imbalance |Male - Female|",
            "axis": {"format": "s"}
        },
        "color": {
            "field": "country",
            "type": "nominal",
            "title": "Country",
            "scale": {"scheme": "viridis"}
        },
        "tooltip": [
            {"field": "country", "type": "nominal", "title": "Country"},
            {"field": "total_arrivals", "type": "quantitative", "title": "Total Arrivals"},
            {"field": "imbalance", "type": "quantitative", "title": "Imbalance"}
        ]
    }
}
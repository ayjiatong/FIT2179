{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Tourist Arrivals Trend: Top 5 Countries (2020 - 2024)"},
    "width": 350,
    "height": 300,
    "data": {
        "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/MY_montharr_states_ns.csv",
        "format": {"type": "csv"}
    },
    "transform": [
        {"filter": "indexof(['SGP', 'IDN', 'CHN', 'THA', 'BRN'], datum.country) >= 0"},
        {
            "calculate": "year(datum.date)",
            "as": "year"
        },
        {
            "aggregate": [{"op": "sum", "field": "arrivals", "as": "yearly_arrivals"}],
            "groupby": ["country", "year"]
        },
        {"filter": "datum.year >= 2020 && datum.year<= 2024"},
        {
            "lookup": "country",
            "from": {
                "data": {
                    "values": [
                        {"iso": "SGP", "name": "Singapore"},
                        {"iso": "IDN", "name": "Indonedia"},
                        {"iso": "CHN", "name": "China"},
                        {"iso": "THA", "name": "Thailand"},
                        {"iso": "BRN", "name": "Brunei Darussalam"}
                    ]
                },
                "key": "iso",
                "fields": ["name"]
            },
            "as": "country_full"
        }
    ],
    "mark": {"type": "line", "point": true},
    "encoding": {
        "x": {
            "field": "year",
            "type": "nominal",
            "title": "Year"
        },
        "y": {
            "field": "yearly_arrivals",
            "type": "quantitative",
            "title": "Yearly Tourist Arrivals"
        },
        "color": {
            "field": "country_full",
            "type": "nominal",
            "title": "Country",
            "scale": {
                "range": ["#4C78A8", "#F58518", "#B279A2", "#9C755F", "#72B7B2"]
            }
        },
        "tooltip": [
            {"field": "country_full", "type": "nominal", "title": "Country"},
            {"field": "year", "type": "ordinal", "title": "Year"},
            {"field": "yearly_arrivals", "type": "quantitative", "title": "Arrivals"}
        ]
    }
}
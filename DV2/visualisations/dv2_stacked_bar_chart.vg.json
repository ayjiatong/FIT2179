{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Malaysia Tourist Arrivals by Gender (2024)"},
    "width": 375,
    "height": 300,
    "data": {
        "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/MY_montharr_states_ns.csv",
        "format": {"type": "csv"}
    },
    "transform": [
        {"calculate": "year(datum.date)", "as": "year"},
        {"filter": "datum.year == 2024"},
        {
            "aggregate": [
                {"op": "sum", "field": "arrivals_male", "as": "male_total"},
                {"op": "sum", "field": "arrivals_female", "as": "female_total"}
            ],
            "groupby": ["soe"]
        },
        {
            "fold": ["male_total", "female_total"],
            "as": ["gender", "value"]
        }
    ],
    "mark": "bar",
    "encoding": {
        "x": {
            "field": "soe",
            "type": "nominal",
            "title": "State",
            "axis": {"labelAngle": -40}
        },
        "y": {
            "field": "value",
            "type": "quantitative",
            "title": "Arrivals",
            "stack": "normalize",
            "axis": {"format": ".0%"}
        },
        "color": {
            "field": "gender",
            "type": "nominal",
            "title": "Gender",
            "scale": {"domain": ["male_total", "female_total"], "range": ["#4C78A8", "#F58518"]}
        },
        "tooltip": [
            {"field": "soe", "type": "nominal", "title": "State"},
            {"field": "gender", "type": "nominal", "title": "Gender"},
            {"field": "value", "type": "quantitative", "title": "Arrivals"}
        ]
    }
}
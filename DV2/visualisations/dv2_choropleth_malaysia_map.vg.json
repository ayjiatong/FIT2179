{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Tourist Arrivals by Malaysia State (2024)"},
    "width": 800,
    "height": 200,
    "projection": {"type": "equalEarth"},
    "data": {
        "url": "https://raw.githubusercontent.com/mptwaktusolat/jakim.geojson/master/malaysia.state.geojson",
        "format": {"type": "json", "property": "features"}
    },
    "transform": [
        {
            "lookup": "properties.name",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/cleaneddata/MY_montharr_states_ns2024total.csv",
                    "format": {"type": "csv"}
                },
                "key": "soe",
                "fields": ["total_arrivals"]
            },
            "as": ["arrivals"]
        }
    ],
    "mark": {
        "type": "geoshape",
        "stroke": "black"
    },
    "encoding": {
        "color": {
            "field": "arrivals", 
            "type": "quantitative", 
            "title": "Number of Tourist",
            "scale": {"scheme": "blues", "type": "sqrt"},
            "legend": {"title": "Arrivals"}
        },
    "tooltip": [
        {"field": "properties.name", "type": "nominal", "title": "States of Malaysia"},
        {"field": "arrivals", "type": "quantitative", "title": "Total Arrivals in 2024"}
    ]
  }
}
{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Top 10 Tourist Arrivals by Country (2024)"},
    "width": 400,
    "height": 300,
    "data": {
        "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/MY_montharr_ns.csv",
        "format": {"type": "csv"}
    },
    "transform": [
        {"filter": "substring(datum.date, 0, 4) == '2024'"},
        {"filter": "datum.country != 'ALL'"},
        {"filter": "datum.arrivals > 0"},
        {
            "lookup": "country",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/lukes/ISO-3166-Countries-with-Regional-Codes/master/all/all.csv",
                    "format": {"type": "csv"}
                },
                "key": "alpha-3",
                "fields": ["name"]
            },
            "as": ["country_full"]
        },
        {
            "aggregate": [{"op": "sum", "field": "arrivals", "as": "total_arrivals"}],
            "groupby": ["country", "country_full"]
        },
        {"window": [{"op": "rank", "as": "rank"}], "sort": [{"field": "total_arrivals", "order": "descending"}]},
        {"filter": "datum.rank <= 10"}
    ],
    "mark": "bar",
    "encoding": {
        "x": {
            "field": "total_arrivals",
            "type": "quantitative",
            "title": "Total Tourist Arrivals (2024)",
            "axis": {"format": "s"}
        },
        "y": {
            "field": "country_full",
            "type": "nominal",
            "title": "Country",
            "sort": {"field": "total_arrivals", "order": "descending"}
        },
        "color": {
            "field": "total_arrivals",
            "type": "quantitative",
            "title": "Total Arrivals",
            "scale": {"scheme": "greens", "reverse": false},
            "legend": null
        },
        "tooltip": [
            {"field": "country_full", "type": "nominal", "title": "Country"},
            {"field": "total_arrivals", "type": "quantitative", "title": "Total Arrivals"}
        ]
    }
}
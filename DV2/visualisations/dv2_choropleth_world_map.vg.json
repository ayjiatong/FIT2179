{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Tourist Arrivals by Country (2024)"},
    "width": 1000,
    "height": 400,
    "projection": {"type": "equalEarth"},
    "data": {
        "url": "https://cdn.jsdelivr.net/npm/visionscarto-world-atlas@1/world/110m.json",
        "format": {"type": "topojson", "feature": "countries"}
    },
    "transform": [
        {
            "lookup": "properties.a3",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/cleaneddata/MY_montharr_ns_2024total.csv",
                    "format": {"type": "csv"}
                },
                "key": "country",
                "fields": ["total_arrivals"]
            },
            "as": ["arrivals"]
        },
        {
            "joinaggregate": [{"op": "max", "field": "arrivals", "as": "max_arrivals"}]
        },
        {
            "calculate": "datum.arrivals / datum.max_arrivals",
            "as": "normalized_arrivals"
        }
    ],
    "mark": {
        "type": "geoshape",
        "stroke": "black"
    },
    "encoding": {
        "color": {
            "field": "normalized_arrivals", 
            "type": "quantitative", 
            "title": "Tourist Arrivals (Normalized)",
            "scale": {"scheme": "greens", "domain": [0, 5000]},
            "legend": {"title": "Normalized Arrivals (0 - 5000)"}
        },
    "tooltip": [
        {"field": "properties.name", "type": "nominal", "title": "Country"},
        {"field": "arrivals", "type": "quantitative", "title": "Total Arrivals"},
        {"field": "normalized_arrivals", "type": "quantitative", "title": "Normalized Value", "format": ".2f"}
    ]
  }
}
{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {"text": "Top States Ranked by Tourist Arrivals (2024)"},
    "width": 350,
    "height": 300,
    "data": {
        "url": "https://raw.githubusercontent.com/ayjiatong/FIT2179/refs/heads/main/DV2/data/MY_montharr_states_ns.csv",
        "format": {
            "type": "csv",
            "parse": {"arrivals": "number"}
        }
    },
    "transform": [
        {"filter": "datum.date >= '2024-01-01' && datum.date < '2025-01-01'"},
        {"filter": "isValid(datum.arrivals) && datum.arrivals > 0"},
        {
            "aggregate": [{"op": "sum", "field": "arrivals", "as": "total_arrivals"}],
            "groupby": ["soe"]
        }
    ],
    "mark": {
        "type": "circle",
        "opacity": 0.5
    },
   "encoding": {
        "x": {
            "field": "soe",
            "type": "nominal",
            "title": "State",
            "axis": {"labelAngle": -40}
        },
        "y": {
            "field": "total_arrivals",
            "type": "quantitative",
            "title": "Total Tourist Arrivals"
        },
        "size": {
            "field": "total_arrivals",
            "type": "quantitative",
            "title": "Total Arrivals"
        },
        "color": {
            "field": "total_arrivals",
            "type": "quantitative",
            "scale": {"scheme": "tealblues"},
            "title": "Total Arrivals"
        },
        "tooltip": [
            {"field": "soe", "type": "nominal", "title": "State"},
            {"field": "total_arrivals", "type": "quantitative", "title": "Total Arrivals"}
        ]
   }
}